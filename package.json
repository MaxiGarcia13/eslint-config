{
  "name": "@maxigarcia/eslint-config",
  "type": "module",
  "version": "1.5.0",
  "description": "Wrapper of Anthony's ESLint config preset",
  "author": "Maximiliano Garcia Mortigliengo",
  "license": "ISC",
  "homepage": "https://github.com/MaxiGarcia13/eslint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxiGarcia13/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/MaxiGarcia13/eslint-config/issues"
  },
  "keywords": [
    "eslint",
    "eslint-config",
    "antfu"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "build": "tsc",
    "prelint": "npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "publish:npm": "npm run build && npm publish --access public"
  },
  "dependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "eslint": "^10.3.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-tailwindcss": "^3.18.3"
  },
  "devDependencies": {
    "@types/eslint-plugin-tailwindcss": "^3.17.0",
    "typescript": "^6.0.3"
  }
}
